# Copy to ".env" on the server:  cp env.sample .env
#
# Absolute public HTTPS base URL (no trailing slash). REQUIRED in production.
# iOS OTA refuses to install unless the manifest + ipa URLs are HTTPS with a
# valid cert, so this must be your real domain served by Caddy.
PUBLIC_BASE_URL=https://apps.example.com

# Where uploaded builds + the SQLite DB live. Point this at a persistent volume.
DATA_DIR=/var/lib/appdrop/data

# Max upload size in bytes (default 500MB).
MAX_UPLOAD_BYTES=524288000

# Default link lifetime in days (0 = never expire).
DEFAULT_EXPIRY_DAYS=30

# Port the Next.js server listens on (Caddy proxies to this).
PORT=3000
