# Copy to ".env" on the server:  cp env.sample .env
#
# Absolute public HTTPS base URL (no trailing slash). REQUIRED in production.
# iOS OTA refuses to install unless the manifest + ipa URLs are HTTPS with a
# valid cert, so this must be your real domain served by Caddy.
PUBLIC_BASE_URL=https://apps.example.com

# Where uploaded builds + the SQLite DB live. Point this at a persistent volume.
DATA_DIR=/var/lib/appdrop/data

# Max upload size in bytes (default 500MB).
MAX_UPLOAD_BYTES=524288000

# Default link lifetime in days (0 = never expire).
DEFAULT_EXPIRY_DAYS=30

# Max distinct apps (by bundle id) kept. Uploading a new app past this evicts the
# oldest app (all its versions) — FIFO. Versions of the same app count as one.
MAX_APPS=20

# Shared team password to gate the upload page + dashboard. Leave EMPTY/unset to
# keep it open (anyone on the LAN can upload). Install links stay public either way.
APP_PASSWORD=

# --- Cloudflare R2 (optional) ---------------------------------------------
# Fill ALL five to store builds on R2 (egress-free, and iOS OTA works over R2's
# HTTPS with NO domain/self-signed cert). Leave blank → falls back to local disk.
# R2_PUBLIC_BASE_URL is the bucket's public URL (r2.dev or a custom domain).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Port the Next.js server listens on (Caddy proxies to this).
PORT=3000
